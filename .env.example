# Local DB mode — set to "true" to use SQLite instead of Supabase (no setup needed)
USE_LOCAL_DB=true
NEXT_PUBLIC_USE_LOCAL_DB=true

# Supabase (not needed when USE_LOCAL_DB=true)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_TEAM_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-xxx

# Analytics (optional — leave blank to disable)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
